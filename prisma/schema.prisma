generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Members ─────────────────────────────────────────────────────────────────

model MemberLevel {
  id        Int      @id @default(autoincrement())
  levelNo   Int      @unique
  levelName String
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id          String    @id @default(cuid())
  userId      String    @unique
  password    String
  name        String
  email       String?   @unique
  phone       String?
  zip         String?
  address     String?
  addressExt  String?
  birth       String?
  gender      String?
  levelId     Int?
  point       Int       @default(0)
  isAdmin     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  level       MemberLevel? @relation(fields: [levelId], references: [id])
  accounts    Account[]
  sessions    Session[]
  boardPosts  BoardPost[]
  comments    BoardComment[]
  orders      Order[]
  wishlist    Wishlist[]
  pointLogs   PointLog[]
  oneToOnes   OneToOne[]
}

// ─── Board ───────────────────────────────────────────────────────────────────

model BoardInfo {
  id          Int      @id @default(autoincrement())
  boardId     String   @unique
  boardName   String   @default("")
  skin        String   @default("default")
  useReply    Boolean  @default(true)
  useHtml     Boolean  @default(false)
  useFile     Boolean  @default(true)
  useCategory Boolean  @default(false)
  useLock     Boolean  @default(false)
  adminOnly   Boolean  @default(false)
  createdAt   DateTime @default(now())

  posts       BoardPost[]
}

model BoardPost {
  id          Int       @id @default(autoincrement())
  boardId     String
  parentId    Int?
  depth       Int       @default(0)
  sortOrder   Int       @default(0)
  userId      String?
  authorName  String
  password    String?
  email       String?
  subject     String
  contents    String    @db.Text
  category    String?
  isLocked    Boolean   @default(false)
  isNotice    Boolean   @default(false)
  useHtml     Boolean   @default(false)
  hit         Int       @default(0)
  ip          String?
  scheduleDate DateTime?
  etc1        String?
  etc2        String?
  etc3        String?
  etc4        String?
  etc5        String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  board       BoardInfo    @relation(fields: [boardId], references: [boardId])
  author      User?        @relation(fields: [userId], references: [id])
  parent      BoardPost?   @relation("replies", fields: [parentId], references: [id])
  replies     BoardPost[]  @relation("replies")
  files       BoardFile[]
  comments    BoardComment[]
}

model BoardFile {
  id         Int       @id @default(autoincrement())
  postId     Int
  origName   String
  savedName  String
  fileSize   Int
  mimeType   String?
  isImage    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  post       BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model BoardComment {
  id         Int       @id @default(autoincrement())
  postId     Int
  userId     String?
  authorName String
  password   String?
  contents   String    @db.Text
  ip         String?
  createdAt  DateTime  @default(now())

  post       BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author     User?     @relation(fields: [userId], references: [id])
}

// ─── Shop ────────────────────────────────────────────────────────────────────

model ProductCategory {
  id        Int       @id @default(autoincrement())
  name      String
  parentId  Int?
  sortOrder Int       @default(0)
  parent    ProductCategory?  @relation("subcategories", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("subcategories")
  products  Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  categoryId  Int?
  name        String
  summary     String?  @db.Text
  description String?  @db.Text
  price       Int      @default(0)
  salePrice   Int?
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    ProductCategory? @relation(fields: [categoryId], references: [id])
  options     ProductOption[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  wishlist    Wishlist[]
}

model ProductOption {
  id        Int    @id @default(autoincrement())
  productId Int
  name      String
  value     String
  addPrice  Int    @default(0)
  stock     Int    @default(0)

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
}

model Cart {
  id        String     @id @default(cuid())
  sessionId String?
  userId    String?
  createdAt DateTime   @default(now())
  items     CartItem[]
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cartId    String
  productId Int
  optionId  Int?
  quantity  Int     @default(1)

  cart      Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product       @relation(fields: [productId], references: [id])
  option    ProductOption? @relation(fields: [optionId], references: [id])
}

model Order {
  id            String      @id @default(cuid())
  orderNo       String      @unique
  userId        String
  status        OrderStatus @default(PENDING)
  totalAmount   Int
  payAmount      Int
  discountAmount Int        @default(0)
  pointUsed     Int         @default(0)
  receiverName  String
  receiverPhone String
  zip           String
  address       String
  addressExt    String?
  deliveryMemo  String?
  couponId      Int?
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id])
  coupon        Coupon?     @relation(fields: [couponId], references: [id])
  items         OrderItem[]
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     String
  productId   Int
  productName String
  optionName  String?
  quantity    Int
  price       Int

  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])
}

model Coupon {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  discountType String  // PERCENT | AMOUNT
  discountValue Int
  minAmount   Int      @default(0)
  maxDiscount Int?
  startDate   DateTime?
  endDate     DateTime?
  usageLimit  Int?
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  orders      Order[]
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    String
  productId Int
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model PointLog {
  id        Int      @id @default(autoincrement())
  userId    String
  amount    Int
  type      String   // EARN | USE | ADMIN
  memo      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Poll ────────────────────────────────────────────────────────────────────

model Poll {
  id        Int      @id @default(autoincrement())
  title     String
  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items     PollItem[]
}

model PollItem {
  id       Int    @id @default(autoincrement())
  pollId   Int
  content  String
  voteCount Int   @default(0)

  poll     Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
}

// ─── One-to-One Inquiry ──────────────────────────────────────────────────────

model OneToOne {
  id          Int      @id @default(autoincrement())
  userId      String?
  authorName  String
  email       String
  phone       String?
  subject     String
  contents    String   @db.Text
  answer      String?  @db.Text
  answeredAt  DateTime?
  status      String   @default("PENDING") // PENDING | ANSWERED
  ip          String?
  createdAt   DateTime @default(now())

  author      User?    @relation(fields: [userId], references: [id])
}

// ─── Popup ───────────────────────────────────────────────────────────────────

model Popup {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String?
  linkUrl   String?
  posX      Int      @default(0)
  posY      Int      @default(0)
  width     Int      @default(400)
  height    Int      @default(300)
  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Mail ────────────────────────────────────────────────────────────────────

model MailSend {
  id          Int      @id @default(autoincrement())
  subject     String
  contents    String   @db.Text
  targetGroup String   @default("ALL")
  sentCount   Int      @default(0)
  createdAt   DateTime @default(now())
}

// ─── Category (general content categories) ───────────────────────────────────

model Category {
  id        Int      @id @default(autoincrement())
  groupId   Int      @default(1) // 1, 2, or 3 matching the PHP category/category2/category3
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
